<!-- ========== CONTACT FORM SECTION — white background ========== -->
<section class="relative py-32 bg-white overflow-hidden">
  <!-- subtle decorative elements (light) -->
  <div class="absolute top-40 right-20 w-96 h-96 bg-[#ceff66] rounded-full mix-blend-multiply filter blur-[120px] opacity-5 animate-pulse"></div>
  <div class="absolute bottom-40 left-20 w-96 h-96 bg-purple-200 rounded-full mix-blend-multiply filter blur-[120px] opacity-5 animate-pulse animation-delay-2000"></div>
  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-[#ceff66]/10 rounded-full rotate-slow"></div>
  <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-[#ceff66]/20 rounded-full rotate-reverse"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-5 sm:px-8 md:px-12 lg:px-20">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-[#ceff66] text-sm font-semibold tracking-[0.3em] uppercase mb-4 block">Get In Touch</span>
      <h2 class="font-['Plus_Jakarta_Sans'] text-4xl md:text-5xl lg:text-6xl font-extrabold text-[#111] mb-6">
        Let's Start a <span class="text-[#ceff66]">Conversation</span>
      </h2>
      <p class="text-[#5a5a5a] text-lg">Whether you need a full BPO setup, a dedicated contact centre, or just have questions — we're ready to help.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Left: Contact Information — light cards -->
      <div class="space-y-8 reveal-left">
        <!-- contact info card (light) -->
        <div class="bg-[#f5f5f5] rounded-[32px] p-8 border border-[#ceff66]/30 shadow-lg">
          <h3 class="font-['Plus_Jakarta_Sans'] text-2xl font-bold text-[#111] mb-6">Contact Information</h3>

          <div class="info-card flex items-start gap-4 p-4 rounded-2xl bg-white border border-gray-200 hover:border-[#ceff66] transition-all mb-4">
            <div class="w-12 h-12 bg-[#ceff66]/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <i class="fas fa-phone text-[#ceff66] text-xl"></i>
            </div>
            <div>
              <p class="text-gray-500 text-sm mb-1">Phone</p>
              <p class="text-[#111] font-semibold text-lg">+92 123 456 7890</p>
              <p class="text-gray-400 text-sm">Mon-Fri 9am-6pm PKT</p>
            </div>
          </div>

          <div class="info-card flex items-start gap-4 p-4 rounded-2xl bg-white border border-gray-200 hover:border-[#ceff66] transition-all mb-4">
            <div class="w-12 h-12 bg-[#ceff66]/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <i class="fas fa-envelope text-[#ceff66] text-xl"></i>
            </div>
            <div>
              <p class="text-gray-500 text-sm mb-1">Email</p>
              <p class="text-[#111] font-semibold text-lg">info@onestop.com</p>
              <p class="text-gray-400 text-sm">support@onestop.com</p>
            </div>
          </div>

          <div class="info-card flex items-start gap-4 p-4 rounded-2xl bg-white border border-gray-200 hover:border-[#ceff66] transition-all mb-4">
            <div class="w-12 h-12 bg-[#ceff66]/20 rounded-xl flex items-center justify-center flex-shrink-0">
              <i class="fas fa-location-dot text-[#ceff66] text-xl"></i>
            </div>
            <div>
              <p class="text-gray-500 text-sm mb-1">Head Office</p>
              <p class="text-[#111] font-semibold text-lg">Karachi, Pakistan</p>
              <p class="text-gray-400 text-sm">Global Reach · Local Support</p>
            </div>
          </div>

          <div class="mt-8">
            <p class="text-gray-500 text-sm mb-4">Follow Us</p>
            <div class="flex gap-3">
              <a href="#" class="w-10 h-10 bg-[#ceff66]/10 rounded-full flex items-center justify-center text-[#111] hover:bg-[#ceff66] transition-all hover:scale-110"><i class="fab fa-linkedin-in"></i></a>
              <a href="#" class="w-10 h-10 bg-[#ceff66]/10 rounded-full flex items-center justify-center text-[#111] hover:bg-[#ceff66] transition-all hover:scale-110"><i class="fab fa-x-twitter"></i></a>
              <a href="#" class="w-10 h-10 bg-[#ceff66]/10 rounded-full flex items-center justify-center text-[#111] hover:bg-[#ceff66] transition-all hover:scale-110"><i class="fab fa-instagram"></i></a>
              <a href="#" class="w-10 h-10 bg-[#ceff66]/10 rounded-full flex items-center justify-center text-[#111] hover:bg-[#ceff66] transition-all hover:scale-110"><i class="fab fa-facebook-f"></i></a>
            </div>
          </div>
        </div>

        <!-- business hours card (light) -->
        <div class="bg-[#f5f5f5] rounded-[32px] p-8 border border-[#ceff66]/30 shadow-lg">
          <h3 class="font-['Plus_Jakarta_Sans'] text-2xl font-bold text-[#111] mb-4">Business Hours</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center border-b border-gray-300 pb-2">
              <span class="text-gray-500">Monday - Friday</span>
              <span class="text-[#111] font-semibold">9:00 AM - 6:00 PM</span>
            </div>
            <div class="flex justify-between items-center border-b border-gray-300 pb-2">
              <span class="text-gray-500">Saturday</span>
              <span class="text-[#111] font-semibold">10:00 AM - 4:00 PM</span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-gray-500">Sunday</span>
              <span class="text-[#111] font-semibold">Closed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form — light card -->
      <div class="reveal-right">
        <div class="bg-[#f5f5f5] rounded-[32px] p-8 md:p-10 border border-[#ceff66]/30 shadow-lg">
          <h3 class="font-['Plus_Jakarta_Sans'] text-2xl font-bold text-[#111] mb-6">Send Us a Message</h3>
          <form action="#" method="POST" class="space-y-6">
            <div>
              <label for="name" class="block text-gray-500 text-sm mb-2">Full Name *</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-[#111] placeholder-gray-400 focus:border-[#ceff66] focus:ring-1 focus:ring-[#ceff66] transition-all">
            </div>
            <div>
              <label for="email" class="block text-gray-500 text-sm mb-2">Email Address *</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-[#111] placeholder-gray-400 focus:border-[#ceff66] focus:ring-1 focus:ring-[#ceff66] transition-all">
            </div>
            <div>
              <label for="phone" class="block text-gray-500 text-sm mb-2">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-[#111] placeholder-gray-400 focus:border-[#ceff66] focus:ring-1 focus:ring-[#ceff66] transition-all">
            </div>
            <div>
              <label for="subject" class="block text-gray-500 text-sm mb-2">Subject *</label>
              <select id="subject" name="subject" required class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-[#111] focus:border-[#ceff66] focus:ring-1 focus:ring-[#ceff66] transition-all">
                <option value="" disabled selected class="bg-white">Select a subject</option>
                <option value="general"     class="bg-white">General Inquiry</option>
                <option value="sales"       class="bg-white">Sales & Pricing</option>
                <option value="support"     class="bg-white">Technical Support</option>
                <option value="partnership" class="bg-white">Partnership Opportunities</option>
                <option value="other"       class="bg-white">Other</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-gray-500 text-sm mb-2">Message *</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-[#111] placeholder-gray-400 focus:border-[#ceff66] focus:ring-1 focus:ring-[#ceff66] transition-all resize-none"></textarea>
            </div>
            <div>
              <button type="submit" class="group relative w-full inline-flex items-center justify-center gap-3 rounded-xl px-8 py-4 bg-[#ceff66] text-black font-semibold text-lg overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_20px_30px_-10px_rgba(206,255,102,0.5)]">
                <span class="relative z-10">Send Message</span>
                <i class="fas fa-paper-plane relative z-10 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"></i>
                <div class="absolute inset-0 bg-white transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-300"></div>
              </button>
            </div>
            <p class="text-gray-400 text-xs text-center">
              By submitting this form, you agree to our <a href="#" class="text-[#ceff66] hover:underline">Privacy Policy</a>.
            </p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>